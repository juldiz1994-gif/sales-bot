# Сату ботының токені (@BotFather-дан алыңыз)
BOT_TOKEN=

# Сіздің Telegram chat ID (сізге хабарламалар келетін жер)
# Білу үшін: @userinfobot-қа жазыңыз
ADMIN_CHAT_ID=

# Негізгі платформа API URL
PLATFORM_API_URL=https://your-platform.railway.app

# Super admin JWT токені (платформаға кіріп, DevTools-тан алыңыз)
PLATFORM_SUPER_ADMIN_TOKEN=

# Платформа frontend URL (клиенттерге жіберіледі)
PLATFORM_URL=https://your-platform.netlify.app

# Kaspi төлем мәліметтері
KASPI_PHONE=+77001234567
KASPI_NAME=Жұлдыз

# Instagram үшін WhatsApp байланыс (wa.me/77001234567 форматында)
OWNER_WHATSAPP=77001234567

# Деректер файлы (өзгертпеңіз)
DATA_FILE=./data/clients.json
